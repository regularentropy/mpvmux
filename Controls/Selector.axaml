<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="using:mpvmux.Controls"
			 xmlns:models="using:mpvmux.Models"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 x:Class="mpvmux.Controls.Selector"
			 x:DataType="local:Selector"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 >
	<DockPanel>
		<Label Content="{CompiledBinding RowName, RelativeSource={RelativeSource AncestorType=local:Selector}}" DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0 0 0 20"></Label>
		<ListBox
		ItemsSource="{CompiledBinding ItemsSource, RelativeSource={RelativeSource AncestorType=local:Selector}}"
		SelectedIndex="{CompiledBinding RowSelectedIndex, RelativeSource={RelativeSource AncestorType=local:Selector}}"
		DockPanel.Dock="Bottom" ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="models:MediaRecord">
					<TextBlock Text="{CompiledBinding Name}" VerticalAlignment="Center"/>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</DockPanel>

	<UserControl.Styles>
		<Style Selector="ListBoxItem">
			<Setter Property="Height" Value="30" />
			<Setter Property="MinHeight" Value="30" />
			<Setter Property="Padding" Value="4,5"></Setter>
			<Setter Property="VerticalAlignment" Value="Center"></Setter>
		</Style>
	</UserControl.Styles>
</UserControl>
