<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:mpvmux.ViewModels"
		x:Class="mpvmux.UpdaterWindow"
		x:DataType="vm:UpdaterViewModel"
        Width="750"
        Height="400"
		Title="Updater">
	<Design.DataContext>
		<vm:UpdaterViewModel />
	</Design.DataContext>

	<Grid Margin="10" RowDefinitions="Auto, *, Auto">
		<TextBlock HorizontalAlignment="Center" Text="{CompiledBinding ReleaseNotesTitle}" />
		<Border ClipToBounds="True" CornerRadius="3" Grid.Row="1" BorderThickness="2" BorderBrush="Black">
			<ScrollViewer>
				<TextBlock Margin="15" Text="{CompiledBinding ReleaseNotes}" Grid.Row="1"/>
			</ScrollViewer>
		</Border>
		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
			<Button Content="Update" Command="{Binding OpenUpdateLinkCommand}" Margin="5"/>
			<Button Content="Close" Click="CloseButton_OnClick" Margin="5"/>
		</StackPanel>
	</Grid>
</Window>
